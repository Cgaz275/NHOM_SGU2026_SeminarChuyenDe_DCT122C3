    {
      "parameters": {
        "jsCode": "// 1. Lấy dữ liệu từ node HTTP trước đó\n// Lưu ý: Nếu node HTTP trả về 1 mảng lớn, n8n thường tách nó ra nhiều item.\n// Dòng này giúp gom lại để xử lý.\nconst allCinemas = $input.all().map(item => item.json);\n\n// 2. Lọc: Chỉ lấy rạp ở \"Hồ Chí Minh\" và ưu tiên rạp \"CGV\"\nconst filtered = allCinemas.filter(rap => \n  (rap.address && rap.address.includes('Hồ Chí Minh')) && \n  (rap.name && rap.name.toUpperCase().includes('CGV'))\n);\n\n// 3. Cắt: Chỉ lấy 5 rạp đầu tiên (QUAN TRỌNG ĐỂ KHÔNG BỊ LỖI QUOTA)\nconst top5 = filtered.slice(0, 5);\n\n// 4. Dọn dẹp: Chỉ lấy Tên và Địa chỉ (bỏ hết mấy cái ID rác đi cho nhẹ token)\nconst finalData = top5.map(rap => ({\n  Ten_Rap: rap.name,\n  Dia_Chi: rap.address\n}));\n\n// 5. Trả về kết quả gọn nhẹ\nreturn [{json: { danh_sach_rap_hcm: finalData }}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1136,
